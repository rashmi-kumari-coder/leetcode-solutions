class Solution {
    public boolean isPalindrome(int x) {

    if (x < 0 || (x % 10 == 0 && x != 0))   return false;
        
        int rem=0, rev =0;
        int original =x;

        while(x!=0){
            rem = x % 10;
            rev = rev*10 + rem;
            x = x/10;
        }
        if(original == rev)
            return true;
        else
            return false;
        
    }
}
